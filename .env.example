# ============================================================
#  Variables de entorno (server-side). NUNCA exponer en el frontend.
#  En Vercel: Project Settings > Environment Variables.
#  Localmente: copiá este archivo a .env (que está en .gitignore).
# ============================================================

# Groq — asistente de ventas IA (función /api/chat)
GROQ_API_KEY=

# Supabase — sistema de reservas (/api/book y /api/slots)
# Usá la SERVICE ROLE KEY (server-side). No la anon key del frontend.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
